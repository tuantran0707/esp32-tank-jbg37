#pragma once

// Sao chép file này thành config.h rồi điền WiFi / ThingsBoard token

#define WIFI_SSID     "YOUR_WIFI"
#define WIFI_PASSWORD "YOUR_PASSWORD"
#define TB_SERVER     "thingsboard.cloud"
#define TB_PORT       1883
#define TB_TOKEN      "YOUR_THINGSBOARD_TOKEN"

// L298N — firmware TRAI = OUT1/OUT2 (ENB), PHAI = OUT3/OUT4 (ENA)
#define PIN_MOTOR_L_PWM 32  // ENB — motor TRAI
#define PIN_MOTOR_L_IN1 27
#define PIN_MOTOR_L_IN2 26
#define PIN_MOTOR_R_PWM 14  // ENA — motor PHAI
#define PIN_MOTOR_R_IN1 25
#define PIN_MOTOR_R_IN2 33

#define PIN_ENC_R_C1 22
#define PIN_ENC_R_C2 23
#define PIN_ENC_L_C1 18
#define PIN_ENC_L_C2 19

#define PIN_BUZZER 5
#define PIN_GAS    36  // VP (SP) — cảm biến khí analog

#define MOTOR_R_SIGN  1
#define MOTOR_L_SIGN  1
#define ENC_R_SIGN    1
#define ENC_L_SIGN   -1

#define PWM_FREQ_HZ   1000  // L298N: 0.5–2 kHz (MOSFET driver TB6612 dùng ~20 kHz)
#define PWM_RES_BITS  8
#define PWM_MAX       255
#define MAX_PWM_DUTY  200
#define PWM_DUTY_LEFT   200
#define PWM_DUTY_RIGHT  160
#define TURN_PWM_LEFT   194
#define TURN_PWM_RIGHT  141
#define TURN_PWM_DUTY   TURN_PWM_LEFT

#define STRAIGHT_FWD_RIGHT_TRIM  0
#define STRAIGHT_REV_LEFT_TRIM   0

#define DEFAULT_COUNTS_PER_CM  111.0f
#define DEFAULT_TURN_90_COUNTS  601L

#define TURN_90_LEFT_COUNTS   601L
#define TURN_90_RIGHT_COUNTS  601L
#define TURN_180_COUNTS       1202L

#define STRAIGHT_ENC_KP        2
#define STRAIGHT_ENC_MAX_TRIM  45
#define TURN_PWM_MIN           85
#define TURN_DECEL_ZONE_PCT    25
#define PWM_MIN_DUTY           70

#define DEFAULT_SCAN_360_MS    1700UL

// Timeout bước tiến thẳng (auto): khớp motor_test phím m
#define STRAIGHT_STEP_TIMEOUT_MS_PER_CM  95
#define STRAIGHT_STEP_TIMEOUT_EXTRA_MS   2000

#define PATH_COMP_Y_CM  8
#define PATH_COMP_X_CM -15

#define MAP_SIZE_CM 150

#define TELEMETRY_INTERVAL_MS    3000UL
#define ATTR_REQUEST_INTERVAL_MS 15000UL
#define TIME_SYNC_INTERVAL_MS    3600000UL
#define GAS_SCAN_SAMPLE_MS       200UL
#define GAS_ALERT_THRESHOLD      700
#define AUTO_DWELL_MS            10000UL

#define TB_SHARED_KEYS \
  "mode,x,y,x_auto,y_auto,run_at_epoch,gas_threshold,stop"

#define SHARED_CONFIG_FILE "/shared_config.json"
